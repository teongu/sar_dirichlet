library(readr)
library(spdep)
library(spatialreg)
library(MLmetrics)
lr <- function(x) {
log(x / rowMeans(x))
}
lr_inv <- function(x) {
exp(x) / rowSums(exp(x))
}
normalize <- function(x) {
(x - mean(x)) / sd(x)
}
