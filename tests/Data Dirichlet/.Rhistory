rmse_aitchison <- function(x1, x2) {
n <- nrow(x1)
D <- ncol(x1)
log_x1 <- log(x1)
log_x2 <- log(x2)
row_rmse <- numeric(n)
for (i in 1:n) {
# Log-ratio matrices for row i
v1 <- as.numeric(log_x1[i, ])
v2 <- as.numeric(log_x2[i, ])
